{
  "manifest_version": 3,
  "name": "SentinelAI Extension",
  "version": "1.0",
  "description": "Scans websites for vulnerabilities and sends DOM intelligence to the SentinelAI Agents.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
